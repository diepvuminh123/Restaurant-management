# App
NODE_ENV=development
FRONTEND_PORT=3000
BACKEND_PORT=5001

# PostgreSQL (Docker)
POSTGRES_DB=restaurant_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
